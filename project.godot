; Engine configuration file.
; Edit this file through the Godot editor when possible.
; The format is intentionally compatible with Godot 4.3 and later.
;
; Format:
;   [section]
;   param=value

config_version=5

[application]

config/name="Echoes of the Shattered Veil"
run/main_scene="res://scenes/bootstrap/main.tscn"
config/description="A narrative-driven pixel-art roguelike about memory, guilt, and chosen identity."
config/version="0.1.0"
config/features=PackedStringArray("4.3", "GL Compatibility")
boot_splash/show_image=false

[autoload]

Logger="*res://scripts/autoload/logger.gd"
ContentRegistry="*res://scripts/autoload/content_registry.gd"
EventBus="*res://scripts/autoload/event_bus.gd"
SaveSystem="*res://scripts/autoload/save_system.gd"
Balance="*res://scripts/autoload/balance.gd"
NarrativeSystem="*res://scripts/autoload/narrative_system.gd"
LoreSystem="*res://scripts/autoload/lore_system.gd"
QuestSystem="*res://scripts/autoload/quest_system.gd"
MetaProgressionSystem="*res://scripts/autoload/meta_progression_system.gd"
InventorySystem="*res://scripts/autoload/inventory_system.gd"
CombatSystem="*res://scripts/autoload/combat_system.gd"
DialogueManager="*res://scripts/autoload/dialogue_manager.gd"
DungeonGenerator="*res://scripts/autoload/dungeon_generator.gd"
FOVSystem="*res://scripts/autoload/fov_system.gd"
UIManager="*res://scripts/autoload/ui_manager.gd"
GameManager="*res://scripts/autoload/game_manager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"
window/handheld/orientation=0

[input]

move_north={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":87)
, Object(InputEventJoypadMotion,"axis":1,"axis_value":-1.0)
]
}
move_north_east={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":69)
]
}
move_east={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":68)
, Object(InputEventJoypadMotion,"axis":0,"axis_value":1.0)
]
}
move_south_east={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":67)
]
}
move_south={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":83)
, Object(InputEventJoypadMotion,"axis":1,"axis_value":1.0)
]
}
move_south_west={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":90)
]
}
move_west={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":65)
, Object(InputEventJoypadMotion,"axis":0,"axis_value":-1.0)
]
}
move_north_west={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":81)
]
}
wait_turn={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":86)
, Object(InputEventJoypadButton,"button_index":3)
]
}
confirm_action={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":32)
, Object(InputEventJoypadButton,"button_index":0)
]
}
cancel_action={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":88)
, Object(InputEventJoypadButton,"button_index":1)
]
}
open_inventory={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":73)
, Object(InputEventJoypadButton,"button_index":2)
]
}
open_character={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":75)
]
}
open_codex={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":76)
]
}
toggle_map={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":77)
]
}
open_message_history={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":72)
]
}
quick_slot_1={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":49)
]
}
quick_slot_2={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":50)
]
}
quick_slot_3={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":51)
]
}
quick_slot_4={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":52)
]
}
zoom_in={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":61)
]
}
zoom_out={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":45)
]
}
pause_game={
"deadzone": 0.5,
"events": [Object(InputEventKey,"physical_keycode":80)
, Object(InputEventJoypadButton,"button_index":6)
]
}

[internationalization]

locale/fallback="en"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
textures/default_filters/use_nearest_mipmap_filter=false
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=false
anti_aliasing/quality/msaa_2d=0
anti_aliasing/quality/screen_space_aa=0
environment/defaults/default_clear_color=Color(0.027, 0.024, 0.043, 1)
